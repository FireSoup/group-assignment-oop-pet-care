package PetOwner;
import java.util.ArrayList;
import java.util.List;

//All animal info will inherit from this class
public class PetOwner {
    private String Id;
    private String name;
    private String phoneNo;
    private String address;
    private String email;
    private String paymentMethod;
    private List<String> petList;

//Pet Owner Data
public PetOwner (String Id, String name, String phoneNo, String address, String email, String paymentMethod, List<String> petList) {
    this.Id = Id;
    this.name = name;
    this.phoneNo = phoneNo;
    this.address = address;
    this.email = email;
    this.paymentMethod = paymentMethod; 
    this.petList = new ArrayList<>();
}

//Pet Name
public void addPet(String petName) {
    petList.add(petName);
}
public void displayOwenerInfo() {
    System.out.printIn("--- Pet Owner Details ---");
    System.out.printIn("ID: " + Id);
    System.out.printIn("Name: " + name);
    System.out.printIn("Phone Number: " + phoneNo);
    System.out.printIn("Address: " + address);
    System.out.printIn("Email: " + email);
    System.out.printIn("Payment Method: " + paymentMethod);
    System.out.printIn("Pets: " + (petList.isEmpty()? "No pets registered" : petList));
    System.out.printIn("----------------------------");
    }
}
